# ============================================
# The Delphi Crucible — Environment Variables
# ============================================
# Copy this file to .env and fill in your real API keys.
# cp .env.example .env

# --- Band API ---
# Get these from https://developers.band.us
# You need one user token + four bot tokens (PM, Quant, Bull, Bear)
BAND_API_KEY=band_u_XXXXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BAND_PM_BOT_TOKEN=band_a_XXXXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BAND_QUANT_BOT_TOKEN=band_a_XXXXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BAND_BULL_BOT_TOKEN=band_a_XXXXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BAND_BEAR_BOT_TOKEN=band_a_XXXXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- AI/ML API (used by PM, Bull, Bear agents) ---
# Get your key from https://aimlapi.com
AIML_API_KEY=your_aiml_api_key_here
AIML_MODEL=gpt-4o

# --- Featherless AI (used by Quant agent) ---
# Get your key from https://featherless.ai
# NOTE: Llama models are gated — use an ungated model like Qwen/Qwen3-32B
#       or connect HuggingFace at https://featherless.ai/models/<model-name>
FEATHERLESS_API_KEY=rc_your_featherless_api_key_here
FEATHERLESS_MODEL=Qwen/Qwen3-32B

# --- Redis ---
# Default works if you're running docker-compose up from the project root
REDIS_URL=redis://localhost:6379/0

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Set this to your ngrok/tunnel URL if using Band webhooks
WEBHOOK_BASE_URL=https://your-tunnel-url.ngrok-free.app